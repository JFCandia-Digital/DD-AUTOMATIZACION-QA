{
  "compilerOptions": {
    "skipLibCheck": true,
    "noErrorTruncation": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "lib": ["esnext", "dom"],
    "moduleResolution": "node16",
    "target": "esnext",
    "module": "node16",
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
