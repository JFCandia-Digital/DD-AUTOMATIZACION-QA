{
  "api": {
    "paths": [
      "src/api-test/**/features/*.feature"
    ],
    "require": [
      "src/hooks/hooks.ts",
      "src/api-test/**/steps/*.steps.ts",
      "src/**/genericSteps/*.steps.ts"
    ],
    "requireModule": [
      "ts-node/register"
    ],
    "timeout": 60000,
    "formatOptions": {
      "snippetInterface": "async-await"
    },
    "format": [
      [
        "html",
        "reports/cucumber-api/api-report.html"
      ],
      "summary",
      "progress-bar",
      "json:reports/cucumber-api/cucumber-report.json"
    ]
  },
  "debug": {
    "paths": [
      "src/front-test/features/*.feature"
    ],
    "require": [
      "src/tools/debug/debugHook.ts",
      "src/front-test/steps/*.ts"
    ],
    "requireModule": [
      "ts-node/register"
    ],
    "timeout": 60000,
    "formatOptions": {
      "snippetInterface": "async-await"
    },
    "format": [
      [
        "html",
        "reports/front/front-report-debug.html"
      ],
      "summary",
      "progress-bar",
      "json:reports/front/cucumber-report-debug.json"
    ]
  }
}
